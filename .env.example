# OpenAI (хмарна модель для експериментів)
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4.1-mini

# Ollama (локальні моделі)
# Рекомендований розподіл:
#   - qwen2.5-coder:14b  → M4 Pro 24GB (спеціалізована code-модель)
#   - llama3.1:8b        → M2 8GB (загальна модель)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:14b

# Сервер
PORT=3001

# Defaults для експериментів
MAX_REFINE_ITERATIONS=3
SANDBOX_TIMEOUT_MS=2000
SAMPLE_ROWS=3
SCHEMA_ANALYSIS_ROWS=100
